<Application x:Class="SmartPlanner.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:SmartPlanner.ViewModels"
             xmlns:conv="clr-namespace:SmartPlanner.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <vm:AppViewModel x:Key="AppViewModel" />
        <conv:PriorityToBrushConverter x:Key="PriorityToBrushConverter" />
        <conv:BoolToBrushConverter x:Key="BoolToBrushConverter" />
    </Application.Resources>
</Application>
