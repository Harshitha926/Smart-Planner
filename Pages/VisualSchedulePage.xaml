<Page x:Class="SmartPlanner.Pages.VisualSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
      Title="Visual Schedule">
    <Page.Resources>
        <CollectionViewSource x:Key="SortedTasks" Source="{Binding TaskManager.Tasks}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Time" Direction="Ascending" />
                <scm:SortDescription PropertyName="PriorityOrder" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background" Value="White" />
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Padding" Value="18" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="BorderBrush" Value="#FFE5E7EB" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="4" Opacity="0.12" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#FFFFF3F2" />
                    <Setter Property="BorderBrush" Value="#FFFECACA" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF2F4F7" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="18" Padding="20" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Visual Schedule" FontSize="28" FontFamily="Segoe UI Semibold" Foreground="#FF111827" />
                    <TextBlock Text="Review your daily timeline with color-coded priorities and active task highlights." FontSize="14" Foreground="#FF6B7280" Margin="0,4,0,0" />
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="Current Task" FontSize="12" Foreground="#FF6B7280" />
                    <TextBlock Text="{Binding TaskManager.ActiveTask.Name, TargetNullValue='No active task'}" FontSize="18" FontWeight="SemiBold" Foreground="#FF111827" />
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Source={StaticResource SortedTasks}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TaskCard}">
                            <Grid ColumnDefinitions="10,*,130" VerticalAlignment="Center">
                                <Border Grid.Column="0" Background="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" Width="10" CornerRadius="5" />
                                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                                    <TextBlock Text="{Binding DisplayTime}" FontSize="16" FontWeight="Bold" Foreground="#FF111827" />
                                    <TextBlock Text="{Binding Name}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,2" />
                                    <TextBlock Text="{Binding DurationLabel}" Foreground="#FF6B7280" />
                                </StackPanel>
                                <Border Grid.Column="2" Background="#FFF8FAFF" CornerRadius="12" Padding="10" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PriorityLabel}" Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" FontWeight="Bold" HorizontalAlignment="Center" />
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
