<Page x:Class="SmartPlanner.Pages.VisualSchedulePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
      Title="Visual Schedule"
      Background="Transparent">
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0F172A" Offset="0" />
            <GradientStop Color="#FF111827" Offset="0.4" />
            <GradientStop Color="#FF1F2937" Offset="1" />
        </LinearGradientBrush>
        <CollectionViewSource x:Key="SortedTasks" Source="{Binding TaskManager.Tasks}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="Time" Direction="Ascending" />
                <scm:SortDescription PropertyName="PriorityOrder" Direction="Ascending" />
            </CollectionViewSource.SortDescriptions>
        </CollectionViewSource>

        <Style x:Key="TaskCard" TargetType="Border">
            <Setter Property="Background" Value="#FF111827" />
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Padding" Value="20" />
            <Setter Property="Margin" Value="0,0,0,18" />
            <Setter Property="BorderBrush" Value="#FF1F2937" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="6" Opacity="0.24" />
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <ScaleTransform ScaleX="1" ScaleY="1" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.01" ScaleY="1.01" />
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#FF111827" />
                    <Setter Property="BorderBrush" Value="#FF2563EB" />
                    <Setter Property="BorderThickness" Value="2" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Opacity" Value="0.6" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="TimeBlock" TargetType="Border">
            <Setter Property="Background" Value="#FF1F2937" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="MinHeight" Value="72" />
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <ScrollViewer Background="Transparent" Padding="28" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,18">
                    <TextBlock Text="Visual Schedule" FontSize="32" FontFamily="Segoe UI Semibold" Foreground="#FFF9FAFB" />
                    <TextBlock Text="  — view your day with style" FontSize="16" Foreground="#FF9CA3AF" VerticalAlignment="Bottom" />
                </StackPanel>

            <Border Background="#FF111827" CornerRadius="24" Padding="24" Margin="0,0,0,24" BorderBrush="#FF1F2937" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Daily Timeline" FontSize="24" FontFamily="Segoe UI Semibold" Foreground="#FFF9FAFB" />
                        <TextBlock Text="Review your scheduled tasks with priority-based coloring." FontSize="14" Foreground="#FF9CA3AF" Margin="0,6,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock Text="Schedule Start" FontSize="12" Foreground="#FF9CA3AF" />
                        <TextBlock Text="{Binding TaskManager.ScheduleStartTime, StringFormat='{}{0:hh:mm tt}'}" FontSize="18" FontWeight="SemiBold" Foreground="#FF60A5FA" />
                    </StackPanel>
                </Grid>
            </Border>

            <ItemsControl ItemsSource="{Binding Source={StaticResource SortedTasks}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TaskCard}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource TimeBlock}" Background="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}">
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayTime}" FontSize="16" FontWeight="Bold" Foreground="White" />
                                        <TextBlock Text="{Binding DurationLabel}" FontSize="12" Foreground="#FFE5E7EB" />
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="20,0,0,0">
                                    <TextBlock Text="{Binding Name}" FontSize="18" FontWeight="SemiBold" Foreground="#FFF9FAFB" />
                                    <TextBlock Text="{Binding PriorityLabel} Priority" FontSize="14" Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" />
                                </StackPanel>

                                <Border Grid.Column="2" Background="#FF4B5563" CornerRadius="12" Padding="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding PriorityLabel}" Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" FontWeight="Bold" />
                                </Border>

                                <StackPanel Grid.Column="3" VerticalAlignment="Center" Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Ellipse Width="12" Height="12" Fill="{Binding IsActive, Converter={StaticResource BoolToBrushConverter}}" Margin="0,0,10,0" />
                                    <TextBlock Text="Now" FontSize="14" Foreground="#FFF9FAFB" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Border Background="#FF374151" CornerRadius="18" Padding="20" Margin="0,20,0,0">
                <StackPanel>
                    <TextBlock Text="Schedule Summary" FontSize="20" FontWeight="SemiBold" Foreground="#FFF9FAFB" Margin="0,0,0,12" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Total Tasks" FontSize="14" Foreground="#FF9CA3AF" />
                            <TextBlock Text="{Binding TaskManager.Tasks.Count}" FontSize="24" FontWeight="Bold" Foreground="#FFF9FAFB" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Completed" FontSize="14" Foreground="#FF9CA3AF" />
                            <TextBlock Text="{Binding TaskManager.Tasks, Converter={StaticResource CompletedTasksConverter}}" FontSize="24" FontWeight="Bold" Foreground="#FF10B981" />
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Remaining" FontSize="14" Foreground="#FF9CA3AF" />
                            <TextBlock Text="{Binding TaskManager.Tasks, Converter={StaticResource RemainingTasksConverter}}" FontSize="24" FontWeight="Bold" Foreground="#FFF59E0B" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
