<Page x:Class="SmartPlanner.Pages.TaskInputPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:SmartPlanner.Models"
      Title="Task Input">
    <Page.Resources>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="18" />
            <Setter Property="Background" Value="White" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,20" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#22000000" BlurRadius="14" ShadowDepth="4" Opacity="0.12" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Background" Value="#FF2563EB" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="12" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="#FFF2F4F7" Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Text="Task Input" FontSize="28" FontFamily="Segoe UI Semibold" Foreground="#FF111827" Margin="0,0,0,16" />

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Add a new task" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,18" />

                    <TextBlock Text="Task Name" FontWeight="SemiBold" Margin="0,0,0,6" />
                    <TextBox Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="10" />

                    <TextBlock Text="Date" FontWeight="SemiBold" Margin="16,16,0,6" />
                    <DatePicker SelectedDate="{Binding NewTaskDate, Mode=TwoWay}" FontSize="14" />

                    <TextBlock Text="Time (HH:mm)" FontWeight="SemiBold" Margin="16,16,0,6" />
                    <TextBox Text="{Binding NewTaskTimeText, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="10" />

                    <TextBlock Text="Duration (minutes)" FontWeight="SemiBold" Margin="16,16,0,6" />
                    <TextBox Text="{Binding NewTaskDuration, UpdateSourceTrigger=PropertyChanged}" FontSize="14" Padding="10" />

                    <TextBlock Text="Priority" FontWeight="SemiBold" Margin="16,16,0,6" />
                    <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedPriority}" FontSize="14" Padding="10" />

                    <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                        <Button Content="Add Task" Command="{Binding AddTaskCommand}" />
                        <Button Content="Generate Schedule" Command="{Binding GenerateScheduleCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Added Tasks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" />
                    <ListView ItemsSource="{Binding TaskManager.Tasks}" SelectedIndex="-1" Background="#FFF8FAFD" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TaskItem}">
                                <Border Background="White" CornerRadius="14" Padding="14" Margin="0,0,0,12" BorderBrush="#FFDBEAFE" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayTime}" FontWeight="Bold" FontSize="16" />
                                            <TextBlock Text="{Binding Name}" Foreground="#FF6B7280" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding DurationLabel}" VerticalAlignment="Center" Foreground="#FF4B5563" />
                                        <Border Grid.Column="2" Background="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" CornerRadius="10" Padding="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                        <Button Grid.Column="3" Content="Remove" Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Background="#FFF1F5F9" Foreground="#FF1F2937" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
