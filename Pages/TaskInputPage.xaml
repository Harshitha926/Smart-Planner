<Page x:Class="SmartPlanner.Pages.TaskInputPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:SmartPlanner.Models"
      Title="Task Input"
      Background="Transparent">
    <Page.Resources>
        <LinearGradientBrush x:Key="PageBackgroundGradient" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#FF0F172A" Offset="0" />
            <GradientStop Color="#FF111827" Offset="0.45" />
            <GradientStop Color="#FF1F2937" Offset="1" />
        </LinearGradientBrush>
        <Style x:Key="CardBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="24" />
            <Setter Property="Background" Value="#FF111827" />
            <Setter Property="Padding" Value="24" />
            <Setter Property="Margin" Value="0,0,0,24" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#000000" BlurRadius="22" ShadowDepth="6" Opacity="0.25" />
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="Background" Value="#FF3B82F6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="16" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF2563EB" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#FF6B7280" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF4B5563" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#FF1F2937" />
            <Setter Property="Foreground" Value="#FFF9FAFB" />
            <Setter Property="BorderBrush" Value="#FF374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#FF1F2937" />
            <Setter Property="Foreground" Value="#FFF9FAFB" />
            <Setter Property="BorderBrush" Value="#FF374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
        <Style TargetType="DatePicker">
            <Setter Property="Background" Value="#FF1F2937" />
            <Setter Property="Foreground" Value="#FFF9FAFB" />
            <Setter Property="BorderBrush" Value="#FF374151" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="MinHeight" Value="40" />
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Top" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Background="{StaticResource PageBackgroundGradient}">
        <ScrollViewer Background="Transparent" Padding="28" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,18">
                    <TextBlock Text="Task Input" FontSize="32" FontFamily="Segoe UI Semibold" Foreground="#FFF9FAFB" />
                    <TextBlock Text="  — add and organize your day" FontSize="16" Foreground="#FF9CA3AF" VerticalAlignment="Bottom" />
                </StackPanel>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Add a new task" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,18" Foreground="#FFF9FAFB" />

                    <TextBlock Text="Task Name" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#FFF9FAFB" />
                    <TextBox Text="{Binding NewTaskName, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Date" FontWeight="SemiBold" Margin="16,16,0,6" Foreground="#FFF9FAFB" />
                    <DatePicker SelectedDate="{Binding NewTaskDate, Mode=TwoWay}" />

                    <TextBlock Text="Time (HH:mm)" FontWeight="SemiBold" Margin="16,16,0,6" Foreground="#FFF9FAFB" />
                    <TextBox Text="{Binding NewTaskTimeText, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Duration (minutes)" FontWeight="SemiBold" Margin="16,16,0,6" Foreground="#FFF9FAFB" />
                    <TextBox Text="{Binding NewTaskDuration, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Priority" FontWeight="SemiBold" Margin="16,16,0,6" Foreground="#FFF9FAFB" />
                    <ComboBox ItemsSource="{Binding PriorityOptions}" SelectedItem="{Binding SelectedPriority}" />

                    <StackPanel Orientation="Horizontal" Margin="0,24,0,0">
                        <Button Content="➕ Add Task" Command="{Binding AddTaskCommand}" />
                        <Button Content="📅 Generate Schedule" Command="{Binding GenerateScheduleCommand}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Filter & Sort" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#FFF9FAFB" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Filter by Priority" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#FFF9FAFB" />
                            <ComboBox ItemsSource="{Binding FilterOptions}" SelectedItem="{Binding FilterPriority}" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Sort by" FontWeight="SemiBold" Margin="0,0,0,6" Foreground="#FFF9FAFB" />
                            <ComboBox ItemsSource="{Binding SortOptions}" SelectedItem="{Binding SortBy}" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Added Tasks" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14" Foreground="#FFF9FAFB" />
                    <ListView ItemsSource="{Binding TaskManager.TasksView}" SelectedIndex="-1" Background="#FF4B5563" BorderThickness="0">
                        <ListView.ItemTemplate>
                            <DataTemplate DataType="{x:Type models:TaskItem}">
                                <Border Background="#FF4B5563" CornerRadius="14" Padding="14" Margin="0,0,0,12" BorderBrush="#FF6B7280" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="110" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayTime}" FontWeight="Bold" FontSize="16" Foreground="#FFF9FAFB" />
                                            <TextBlock Text="{Binding Name}" Foreground="#FF9CA3AF" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding DurationLabel}" VerticalAlignment="Center" Foreground="#FFD1D5DB" />
                                        <Border Grid.Column="2" Background="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" CornerRadius="10" Padding="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding PriorityLabel}" Foreground="White" FontWeight="SemiBold" />
                                        </Border>
                                        <Button Grid.Column="3" Content="✅ Done" Command="{Binding DataContext.MarkCompletedCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Background="#FF10B981" />
                                        <Button Grid.Column="4" Content="🗑️ Remove" Command="{Binding DataContext.RemoveTaskCommand, RelativeSource={RelativeSource AncestorType=Page}}" CommandParameter="{Binding}" Style="{StaticResource SecondaryButton}" Background="#FFEF4444" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
