<Window x:Class="SmartPlanner.Windows.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Reminder"
        Height="320"
        Width="480"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None"
        AllowsTransparency="True">
    <Border Background="#FF1F2937" CornerRadius="20" Padding="24" BorderBrush="#FF374151" BorderThickness="2">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="20" ShadowDepth="8" Opacity="0.4" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="⏰ Task Reminder" FontSize="28" FontFamily="Segoe UI Semibold" Foreground="#FFF9FAFB" HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="Stay on track with your current task." FontSize="14" Foreground="#FF9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,20" />
            <Border Background="#FF374151" CornerRadius="12" Padding="16" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Task" FontWeight="SemiBold" Foreground="#FFF9FAFB" />
                    <TextBlock Text="{Binding Name}" FontSize="20" Margin="0,4,0,12" Foreground="#FF60A5FA" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Start" FontWeight="SemiBold" Foreground="#FF9CA3AF" />
                            <TextBlock Text="{Binding Time, StringFormat='{}{0:hh:mm tt}'}" FontSize="16" Foreground="#FFF9FAFB" />
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Duration" FontWeight="SemiBold" Foreground="#FF9CA3AF" />
                            <TextBlock Text="{Binding DurationLabel}" FontSize="16" Foreground="#FFF9FAFB" />
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            <Border Background="#FF4B5563" CornerRadius="12" Padding="12" Margin="0,0,0,20">
                <TextBlock Text="{Binding PriorityLabel} Priority" Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" FontWeight="Bold" HorizontalAlignment="Center" FontSize="16" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="12">
                <Button Content="✅ Done" Click="Done_Click" Background="#FF10B981" Foreground="White" Padding="16,8" FontSize="14" FontWeight="SemiBold" />
                <Button Content="⏰ Snooze 5 min" Click="Snooze_Click" Background="#FFF59E0B" Foreground="White" Padding="16,8" FontSize="14" FontWeight="SemiBold" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
