<Window x:Class="SmartPlanner.Windows.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Reminder"
        Height="260"
        Width="440"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        WindowStyle="None">
    <Border Background="White" CornerRadius="20" Padding="24" BorderBrush="#FFE5E7EB" BorderThickness="1">
        <StackPanel>
            <TextBlock Text="Task Reminder" FontSize="24" FontFamily="Segoe UI Semibold" Foreground="#FF111827" />
            <TextBlock Text="Stay on track with your current task." FontSize="14" Foreground="#FF6B7280" Margin="0,6,0,18" />
            <TextBlock Text="Task" FontWeight="SemiBold" Foreground="#FF374151" />
            <TextBlock Text="{Binding Name}" FontSize="18" Margin="0,4,0,10" />
            <Grid ColumnDefinitions="*,*" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="Start" FontWeight="SemiBold" Foreground="#FF374151" />
                    <TextBlock Text="{Binding Time, StringFormat='{}{0:hh:mm tt}'}" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Duration" FontWeight="SemiBold" Foreground="#FF374151" />
                    <TextBlock Text="{Binding DurationLabel}" />
                </StackPanel>
            </Grid>
            <Border Background="#FFF8FAFF" CornerRadius="12" Padding="12" Margin="0,0,0,18">
                <TextBlock Text="{Binding PriorityLabel}" Foreground="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}" FontWeight="Bold" HorizontalAlignment="Center" />
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10">
                <Button Content="Snooze 5 min" Click="Snooze_Click" Background="#FFF59E0B" />
                <Button Content="Done" Click="Done_Click" Background="#FF10B981" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
